# Neon PostgreSQL Connection
DATABASE_URL=jdbc:postgresql://<neon-host-name>/neondb?sslmode=require
DATABASE_USERNAME=your_db_username
DATABASE_PASSWORD=your_db_password

# Spring Security JWT Configuration
# Base64 encoded secret key (min 256 bits for HS256 algorithm)
JWT_SECRET=your_jwt_secret_base64_encoded_key_here
